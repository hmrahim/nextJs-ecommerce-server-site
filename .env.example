# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://127.0.0.1:27017/moom24

# JWT
JWT_SECRET=change-me-please-32+chars
JWT_REFRESH_SECRET=change-me-please-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Cloudinary (frontend uploads; backend signs requests)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
